{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Speedeerq/Audi-MMI-3G-Coding-Adaptation-Datasets/schemas/ui_observation.schema.json",
  "title": "UI Observation",
  "description": "Schema for read-only MMI/UI observations. Visibility is not treated as confirmed function.",
  "type": "object",
  "additionalProperties": false,
  "required": ["observationId", "area", "status", "evidence"],
  "properties": {
    "observationId": {"type": "string"},
    "campaignId": {"type": "string"},
    "baselineId": {"type": "string"},
    "area": {"type": "string"},
    "menuPath": {"type": "string"},
    "visible": {"type": "boolean"},
    "selectable": {"type": "boolean"},
    "functionalEffectObserved": {"type": "boolean"},
    "interpretationStatus": {"$ref": "#/$defs/claimStatus"},
    "relatedModulesSuspected": {
      "type": "array",
      "items": {"type": "string"}
    },
    "capturedAt": {"type": "string", "format": "date-time"},
    "evidence": {
      "type": "array",
      "items": {"$ref": "#/$defs/evidenceRef"}
    },
    "status": {"$ref": "#/$defs/evidenceStatus"},
    "notes": {"type": "string"}
  },
  "$defs": {
    "claimStatus": {
      "type": "string",
      "enum": ["UNKNOWN", "HYPOTHESIS", "TO_VERIFY", "VARIANT", "CONFIRMED", "BLOCKED"]
    },
    "evidenceStatus": {
      "type": "string",
      "enum": ["TO_CAPTURE", "PARTIAL", "CAPTURED", "BLOCKED", "UNKNOWN"]
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "path"],
      "properties": {
        "type": {"type": "string", "enum": ["PHOTO", "VIDEO", "SCREENSHOT", "LOG", "NOTE", "OTHER"]},
        "path": {"type": "string"},
        "sanitized": {"type": "boolean"},
        "notes": {"type": "string"}
      }
    }
  }
}
